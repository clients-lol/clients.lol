{
  "name": "clients-lol",
  "version": "0.0.1",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "@tsconfig/bun": "^1.0.8",
      "@types/bun": "1.3.0",
      "@types/node": "22.13.9",
      "typescript": "5.8.2",
      "zod": "^3.25.76"
    }
  },
  "type": "module",
  "scripts": {
    "build": "bun ./packages/web/script/build.ts",
    "dev": "bun ./packages/web/script/dev.ts",
    "deploy": "sst deploy",
    "validate": "bun ./packages/core/script/validate.ts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "bunx tsc -p packages/core/tsconfig.json --noEmit && bunx tsc -p packages/web/tsconfig.json --noEmit",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "dependencies": {
    "sst": "4.12.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260424.1",
    "@tsconfig/bun": "catalog:",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "oxfmt": "^0.27.0",
    "oxlint": "^1.42.0",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.0"
}
