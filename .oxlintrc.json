{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "jsx-a11y"],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "pedantic": "warn",
    "perf": "warn",
    "style": "warn",
    "restriction": "warn",
    "nursery": "allow"
  },
  "rules": {
    "typescript/no-explicit-any": "warn",
    "no-console": "warn",
    "no-debugger": "error",
    "no-alert": "error",
    "prefer-const": "error",
    "no-var": "error",
    "no-unused-vars": "error",
    "no-duplicate-imports": "error",
    "eqeqeq": "error",
    "curly": "error",
    "typescript/prefer-readonly": "warn",
    "typescript/no-unnecessary-type-assertion": "error",
    "typescript/no-non-null-assertion": "warn",
    "typescript/prefer-as-const": "error",
    "typescript/prefer-includes": "error",
    "typescript/prefer-string-starts-ends-with": "error",
    "jsx-a11y/alt-text": "error",
    "jsx-a11y/anchor-has-content": "error",
    "jsx-a11y/anchor-is-valid": "warn"
  },
  "env": {
    "builtin": true,
    "es2022": true,
    "node": true,
    "browser": true,
    "webworker": true
  },
  "globals": {
    "Env": "readonly",
    "fetch": "readonly",
    "Request": "readonly",
    "Response": "readonly"
  },
  "ignorePatterns": [
    "dist/**",
    ".sst/**",
    ".astro/**",
    "node_modules/**",
    "*.min.js",
    "*.config.js",
    "*.config.mjs",
    ".agents/"
  ],
  "overrides": [
    {
      "files": ["sst.config.ts"],
      "rules": {
        "typescript/triple-slash-reference": "off",
        "no-console": "off",
        "no-ternary": "off",
        "no-undefined": "off",
        "sort-keys": "off",
        "require-await": "off"
      }
    },
    {
      "files": ["packages/**/*.ts", "packages/**/*.js"],
      "rules": {
        "func-style": "off",
        "no-console": "warn",
        "no-ternary": "off",
        "sort-imports": "off"
      }
    },
    {
      "files": ["packages/core/script/**/*.ts", "packages/web/script/**/*.ts"],
      "rules": {
        "max-lines-per-function": "off",
        "max-statements": "off",
        "no-console": "off"
      }
    },
    {
      "files": ["packages/web/src/**/*.js"],
      "rules": {
        "id-length": "off",
        "max-statements": "off",
        "sort-keys": "off"
      }
    },
    {
      "files": ["*.config.*", "*.mjs"],
      "rules": {
        "no-console": "off",
        "sort-keys": "off"
      }
    },
    {
      "files": ["sst-env.d.ts"],
      "rules": {
        "capitalized-comments": "off",
        "ban-tslint-comment": "off"
      }
    }
  ]
}
