---
import type { CollectionEntry } from "astro:content";

interface Props {
	clients: CollectionEntry<"clients">[];
}

const { clients } = Astro.props;
---

<section>
	<h2>Clients</h2>
	<div class="clients-grid">
		{
			clients.map((client) => (
				<article class="client-card">
					<div class="client-header-row">
						<h3>
							<a href={`/clients/${client.id.replace(/\.md$/, "")}`}>
								{client.data.name}
							</a>
						</h3>
						<span
							class={`status-indicator status-${client.data.status.toLowerCase()}`}
						>
							{client.data.status}
						</span>
					</div>
					<p class="client-description">{client.data.description}</p>
					<div class="client-meta">
						<span class="badge">{client.data.os}</span>
						<span class="badge">{client.data.type}</span>
						{client.data.pricing.length > 0 && (
							<span class="badge badge-price">
								{client.data.pricing.length === 1 
									? `${client.data.pricing[0].price}${client.data.pricing[0].period ? `/${client.data.pricing[0].period}` : ''}`
									: `From ${client.data.pricing[0].price}`
								}
							</span>
						)}
					</div>
					<div class="client-features-preview">
						{client.data.features.slice(0, 3).map((feature) => (
							<span class="feature-tag">{feature}</span>
						))}
						{client.data.features.length > 3 && (
							<span class="feature-tag">+{client.data.features.length - 3} more</span>
						)}
					</div>
				</article>
			))
		}
	</div>
</section>

<style>
	.clients-grid {
		display: grid;
		gap: var(--space-6);
		grid-template-columns: 1fr;
	}

	.client-card {
		background-color: var(--color-bg-elevated);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		padding: var(--space-6);
		transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
	}

	.client-card:hover {
		border-color: var(--color-accent);
		box-shadow: var(--shadow-md);
	}

	.client-header-row {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		margin-bottom: var(--space-3);
		gap: var(--space-4);
	}

	.client-header-row h3 {
		margin: 0;
		font-size: var(--text-xl);
	}

	.client-header-row a {
		text-decoration: none;
		color: var(--color-text);
	}

	.client-header-row a:hover {
		color: var(--color-accent);
	}

	.status-indicator {
		display: inline-block;
		padding: var(--space-1) var(--space-2);
		border-radius: var(--radius-sm);
		font-size: var(--text-xs);
		font-weight: 600;
		white-space: nowrap;
	}

	.status-active {
		background-color: #dcfce7;
		color: #166534;
	}

	.status-inactive {
		background-color: var(--stone-200);
		color: var(--stone-600);
	}

	.status-discontinued {
		background-color: #fee2e2;
		color: #991b1b;
	}

	.status-unknown {
		background-color: var(--stone-100);
		color: var(--stone-500);
	}

	.client-description {
		color: var(--color-text-muted);
		font-size: var(--text-sm);
		margin-bottom: var(--space-4);
		line-height: 1.6;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.client-meta {
		display: flex;
		gap: var(--space-2);
		margin-bottom: var(--space-4);
		flex-wrap: wrap;
	}

	.badge {
		display: inline-block;
		padding: var(--space-1) var(--space-2);
		background-color: var(--stone-200);
		border-radius: var(--radius-sm);
		font-size: var(--text-xs);
		font-weight: 600;
		color: var(--stone-700);
	}

	.badge-price {
		background-color: var(--terracotta-300);
		color: var(--stone-800);
	}

	.client-features-preview {
		display: flex;
		gap: var(--space-2);
		flex-wrap: wrap;
	}

	.feature-tag {
		display: inline-block;
		padding: var(--space-1) var(--space-2);
		background-color: transparent;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		font-size: var(--text-xs);
		color: var(--color-text-muted);
	}
</style>
