---
import Layout from "../layouts/Layout.astro";
import Config from "../../config.mjs";
---

<Layout>
    <header>
        <p class="subtitle">Personal Blog</p>
        <h1>Alex Marshall</h1>
    </header>
    <section>
        <p>
            Backend engineer focused on infrastructure and systems design. Flexible across teams and independent work.
        </p>
    </section>

    <hr />

    <section>
        <h2>Experience</h2>
        <div class="experience">
            <div class="role">
                <h3>DevOps / Backend Engineer</h3>
                <p class="company">Tritan Internet LLC - 2022 to 2025</p>
                <p>
                    Designed and shipped core backend systems that now power Tritan's billing, security, and intelligence operations. 
                    Engineered solutions spanning APIs, real-time data processing, and open internet infrastructure using TypeScript, MongoDB, and Redis.
                </p>
            </div>
        </div>
    </section>
</Layout>


    <hr />

    <section>
        <h2>Technologies</h2>
        <p class="technologies">
            TypeScript, Node.js, Express.js, Hono<br />
            PostgreSQL, MongoDB, Redis<br />
            AWS, Cloudflare, Docker, SST<br />
            OAuth2, JWT, WebSockets
        </p>
    </section>

    <hr />

    <section>
        <h2>Get in touch</h2>
    <p>Feel free to reach out:</p>
    <div class="links">
        <a href={`mailto:${Config.email}`}>Email</a>
        <a href={Config.github}>GitHub</a>
    </div>
</section>
