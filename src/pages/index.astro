---
import Layout from "../layouts/Layout.astro";
import { getClients } from "../lib/clients";

const clients = await getClients();
---

<Layout title="clients.lol - VRChat Client Directory">
    <header>
        <div class="left">
            <h1>clients.lol</h1>
            <span class="slash"></span>
            <p>An open-source database of VRChat clients</p>
        </div>
        <div class="right">
            <a
                class="github"
                target="_blank"
                rel="noopener noreferrer"
                href="https://github.com/clients-lol/clients.lol"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                >
                    <path
                        fill="currentColor"
                        d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5c.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34c-.46-1.16-1.11-1.47-1.11-1.47c-.91-.62.07-.6.07-.6c1 .07 1.53 1.03 1.53 1.03c.87 1.52 2.34 1.07 2.91.83c.09-.65.35-1.09.63-1.34c-2.22-.25-4.55-1.11-4.55-4.92c0-1.11.38-2 1.03-2.71c-.1-.25-.45-1.29.1-2.64c0 0 .84-.27 2.75 1.02c.79-.22 1.65-.33 2.5-.33s1.71.11 2.5.33c1.91-1.29 2.75-1.02 2.75-1.02c.55 1.35.2 2.39.1 2.64c.65.71 1.03 1.6 1.03 2.71c0 3.82-2.34 4.66-4.57 4.91c.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0 0 12 2"
                    ></path>
                </svg>
            </a>
            <div class="search-container">
                <input type="text" id="search" placeholder="Search clients" />
                <span class="search-shortcut">⌘K</span>
            </div>
            <button id="help">How to use</button>
        </div>
    </header>

    <table id="clients-table">
        <thead>
            <tr>
                <th class="sortable" data-type="string"
                    >Name <span class="sort-indicator"></span></th
                >
                <th class="sortable" data-type="string"
                    >Type <span class="sort-indicator"></span></th
                >
                <th class="sortable" data-type="string"
                    >OS <span class="sort-indicator"></span></th
                >
                <th class="sortable" data-type="string"
                    >Status <span class="sort-indicator"></span></th
                >
                <th class="sortable" data-type="string"
                    >Website <span class="sort-indicator"></span></th
                >
                <th class="sortable" data-type="string"
                    >Access <span class="sort-indicator"></span></th
                >
                <th class="sortable" data-type="string"
                    >Staff quality <span class="sort-indicator"></span></th
                >
                <th class="sortable capability" data-type="string"
                    >Movement <span class="sort-indicator"></span></th
                >
                <th class="sortable capability" data-type="string"
                    >ESP <span class="sort-indicator"></span></th
                >
                <th class="sortable capability" data-type="string"
                    >Teleports <span class="sort-indicator"></span></th
                >
                <th class="sortable capability" data-type="string"
                    >VR <span class="sort-indicator"></span></th
                >
                <th class="sortable capability" data-type="string"
                    >Crashers <span class="sort-indicator"></span></th
                >
                <th class="sortable capability" data-type="string"
                    >Protections <span class="sort-indicator"></span></th
                >
            </tr>
        </thead>
        <tbody>
            {
                clients.map((client) => (
                    <tr>
                        <td>{client.data.name}</td>
                        <td>{client.data.type}</td>
                        <td>{client.data.os}</td>
                        <td>{client.data.status}</td>
                        <td>
                            {client.data.website ? (
                                <a class="muted-link" href={client.data.website} target="_blank" rel="noopener noreferrer">{client.data.website}</a>
                            ) : (
                                "-"
                            )}
                        </td>
                        <td>{client.data.access}</td>
                        <td>{client.data.staffQuality}</td>
                        <td class="capability-cell">
                            {client.data.features.movement ? "Yes" : "-"}
                        </td>
                        <td class="capability-cell">
                            {client.data.features.esp ? "Yes" : "-"}
                        </td>
                        <td class="capability-cell">
                            {client.data.features.teleports ? "Yes" : "-"}
                        </td>
                        <td class="capability-cell">
                            {client.data.features.vrSupport ? "Yes" : "-"}
                        </td>
                        <td class="capability-cell">
                            {client.data.features.crashers ? "Yes" : "-"}
                        </td>
                        <td class="capability-cell">
                            {client.data.features.protections ? "Yes" : "-"}
                        </td>
                    </tr>
                ))
            }
        </tbody>
    </table>

    <dialog id="modal">
        <div class="header">
            <h2>How to use</h2>
            <button id="close" aria-label="Close">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <line
                        x1="18"
                        y1="6"
                        x2="6"
                        y2="18"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"></line>
                    <line
                        x1="6"
                        y1="6"
                        x2="18"
                        y2="18"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"></line>
                </svg>
            </button>
        </div>
        <div class="body">
            <p>
                <a href="/">clients.lol</a> is a directory of VRChat clients with
                access, compatibility, and feature info.
            </p>
            <p>
                Use search to filter rows and click a column header to sort the
                table.
            </p>
            <h2>API</h2>
            <p>You can access this data through an API.</p>
            <div class="code-block">
                <code
                    >curl <a href="/api.json">https://clients.lol/api.json</a
                    ></code>
            </div>
            <p>Use the client name as the main lookup field.</p>
            <h2>Contribute</h2>
            <p>
                The data is stored in Markdown files in the repo. Edit the data
                and open a pull request.
            </p>
        </div>
        <div class="footer">
            <a
                href="https://github.com/clients-lol/clients.lol/tree/master/src/content/clients"
                target="_blank"
                rel="noopener noreferrer">Edit on GitHub</a
            >
            <a
                href="https://github.com/clients-lol/clients.lol"
                target="_blank"
                rel="noopener noreferrer">Open a PR or issue</a
            >
        </div>
    </dialog>

    <script>
        const modal = document.getElementById("modal");
        const modalClose = document.getElementById("close");
        const help = document.getElementById("help");
        const search = document.getElementById("search");
        const table = document.getElementById("clients-table");
        const tbody = table.querySelector("tbody");

        let y = 0;

        help.addEventListener("click", () => {
            y = window.scrollY;
            document.body.style.position = "fixed";
            document.body.style.top = `-${y}px`;
            modal.showModal();
        });

        function closeDialog() {
            modal.close();
            document.body.style.position = "";
            document.body.style.top = "";
            window.scrollTo(0, y);
        }

        modalClose.addEventListener("click", closeDialog);
        modal.addEventListener("cancel", closeDialog);
        modal.addEventListener("click", (e) => {
            if (e.target === modal) closeDialog();
        });

        function getQueryParams() {
            return new URLSearchParams(window.location.search);
        }

        function updateQueryParams(updates) {
            const params = getQueryParams();
            for (const [key, value] of Object.entries(updates)) {
                if (value) params.set(key, value);
                else params.delete(key);
            }
            const newPath = params.toString()
                ? `${window.location.pathname}?${params.toString()}`
                : window.location.pathname;
            window.history.pushState({}, "", newPath);
        }

        function getColumnNameForURL(headerEl) {
            const text = headerEl.textContent?.trim().toLowerCase() || "";
            return text
                .replace(/↑|↓/g, "")
                .trim()
                .split(/\s+/)
                .slice(0, 2)
                .join("-");
        }

        function getColumnIndexByUrlName(name) {
            const headers = document.querySelectorAll("th.sortable");
            return Array.from(headers).findIndex(
                (header) => getColumnNameForURL(header) === name,
            );
        }

        function getCellValue(cell) {
            const text = cell.textContent?.trim() || "";
            if (text === "-") return "";
            return text;
        }

        let currentSort = { column: -1, direction: "asc" };

        function sortTable(column, direction) {
            const header = document.querySelectorAll("th.sortable")[column];
            currentSort = { column, direction };
            updateQueryParams({
                sort: getColumnNameForURL(header),
                order: direction,
            });

            const rows = Array.from(tbody.querySelectorAll("tr"));
            rows.sort((a, b) => {
                const aValue = getCellValue(a.cells[column]);
                const bValue = getCellValue(b.cells[column]);
                const comparison = aValue.localeCompare(bValue);
                return direction === "asc" ? comparison : -comparison;
            });
            rows.forEach((row) => tbody.appendChild(row));

            document.querySelectorAll("th.sortable").forEach((th, i) => {
                const indicator = th.querySelector(".sort-indicator");
                indicator.textContent =
                    i === column ? (direction === "asc" ? "↑" : "↓") : "";
            });
        }

        search.addEventListener("input", () => {
            const value = search.value.toLowerCase();
            const rows = tbody.querySelectorAll("tr");

            rows.forEach((row) => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(value) ? "" : "none";
            });

            updateQueryParams({ search: value || null });
        });

        document.addEventListener("keydown", (e) => {
            if ((e.metaKey || e.ctrlKey) && e.key === "k") {
                e.preventDefault();
                search.focus();
            }
        });

        search.addEventListener("keydown", (e) => {
            if (e.key === "Escape") {
                search.value = "";
                search.dispatchEvent(new Event("input"));
                search.blur();
            }
        });

        document.querySelectorAll("th.sortable").forEach((header, index) => {
            header.addEventListener("click", () => {
                const direction =
                    currentSort.column === index &&
                    currentSort.direction === "asc"
                        ? "desc"
                        : "asc";
                sortTable(index, direction);
            });
        });

        function initializeFromURL() {
            const params = getQueryParams();

            const searchQuery = params.get("search");
            if (searchQuery) {
                search.value = searchQuery;
                search.dispatchEvent(new Event("input"));
            }

            const columnName = params.get("sort");
            if (columnName) {
                const columnIndex = getColumnIndexByUrlName(columnName);
                if (columnIndex !== -1) {
                    const direction = params.get("order") || "asc";
                    sortTable(columnIndex, direction);
                }
            }
        }

        document.addEventListener("DOMContentLoaded", initializeFromURL);
        window.addEventListener("popstate", initializeFromURL);
    </script>
</Layout>
