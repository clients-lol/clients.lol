---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Clients from "../components/Clients.astro";
import Config from "../../config.mjs";
import { sortClients } from "../utils/sortClients";

const clients = await getCollection("clients");
const sortedClients = sortClients(clients);
---

<Layout title="clients.lol - VRChat Client Directory">
    <header class="page-header">
        <h1 transition:name="home-title">Client Hub</h1>
        <p class="subtitle">A curated directory of VRChat clients</p>
    </header>

    <section>
        <p>
            Discover the best VRChat clients with comprehensive information
            about features, pricing, and quality. Each client is reviewed and
            categorized for easy comparison.
        </p>
    </section>

    <hr />

    <Clients clients={sortedClients} />

    <hr />

    <section>
        <h2>About</h2>
        <p>
            clients.lol is an independent directory providing unbiased
            information about VRChat modification clients. We don't endorse or
            affiliate with any specific client—our goal is to help users make
            informed decisions.
        </p>
    </section>

    <hr />

    <section>
        <h2>Get in touch</h2>
        <p>Found an issue or want to suggest a client?</p>
        <div class="links">
            <a href={`mailto:${Config.email}`}>Email</a>
            <a href={Config.github}>GitHub</a>
        </div>
    </section>
</Layout>

<style>
    .links {
        display: flex;
        gap: var(--space-4);
        margin-top: var(--space-4);
    }

    .links a {
        font-size: var(--text-sm);
        font-weight: 500;
    }
</style>
