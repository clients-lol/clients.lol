---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const posts = await getCollection("writing", ({ data }) => import.meta.env.PROD ? !data.draft : true);

// Sort by date, newest first
const sortedPosts = posts.sort(
  (first, second) => second.data.pubDate.valueOf() - first.data.pubDate.valueOf()
);
---

<Layout
  title="Writing - Alex Marshall"
  description="Technical articles on backend engineering, infrastructure, and systems design."
>
  <header class="page-header">
    <p class="subtitle">Archive</p>
    <h1 transition:name="writing-title">Writing</h1>
  </header>

  <section>
    <p>
      Thoughts on backend engineering, infrastructure, and the craft of building
      reliable systems. I write about TypeScript, Node.js, databases, cloud
      infrastructure, and the occasional deep dive into technical topics.
    </p>
  </section>

  <hr />

  <ul class="writing-list">
    {
      sortedPosts.map((post) => (
        <li>
          <a href={`/writing/${post.id.replace(/\.mdx?$/, "")}`}>
            <h3>{post.data.title}</h3>
            <p class="excerpt">{post.data.description}</p>
            <span class="date">
              {post.data.pubDate.toLocaleDateString("en-US", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </span>
          </a>
        </li>
      ))
    }
  </ul>

  {
    sortedPosts.length === 0 && (
      <p class="no-posts">No posts yet. Check back soon!</p>
    )
  }
</Layout>

<style>
  .no-posts {
    text-align: center;
    color: var(--color-text-muted);
    font-style: italic;
    margin-top: var(--space-12);
  }
</style>
